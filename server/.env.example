# Postgres connection string (e.g. from Neon, Supabase, or a local Postgres).
# Neon example: postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/schoolhub?schema=public"

# Port the API/server listens on (Render sets this automatically).
PORT=4000

# Optional: enables real "Generate with AI" email drafting via Claude.
# Without it, the app falls back to a local draft generator.
# ANTHROPIC_API_KEY=sk-ant-...
