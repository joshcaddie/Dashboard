generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            Int       @id @default(autoincrement())
  name          String
  contact       String    @default("—")
  type          String    @default("Client")
  region        String    @default("")
  roll          String    @default("—")
  website       String    @default("")
  ws            String    @default("schoolwebsites")
  businessType  String    @default("Primary School")
  notes         String    @default("")
  phone         String    @default("")
  email         String    @default("")
  websiteHost   String    @default("") // where the website is hosted (e.g. Scala)
  domainHost    String    @default("") // where the domain / DNS is managed (registrar / IT)
  in7777        String    @default("") // (obscured) domain login username or email
  p777777       String    @default("") // (obscured) domain secret, AES-256-GCM encrypted at rest
  adSpend       Int       @default(0) // Google Ads: monthly ad spend
  mgmtFee       Int       @default(0) // Google Ads: monthly management fee
  lastContacted String? // display string, e.g. "Jul 6, 2026"
  auditUrl      String    @default("") // Caddie Optimise shareable SEO report (set via webhook)
  auditPdf      String    @default("") // report PDF url
  auditScore    Int? // overall SEO score at last report
  auditAt       String    @default("") // display date of the last audit
  proposalUrl   String    @default("") // Caddie Optimise client proposal PDF (set via webhook)
  proposalAt    String    @default("") // display date of the proposal
  contacts      Contact[]
}

// Google Ads: dated notes attached to a client's ad account.
model AdNote {
  id        Int      @id @default(autoincrement())
  clientId  Int
  date      String   @default("") // display date, e.g. "Jul 8, 2026"
  text      String   @default("")
  createdAt DateTime @default(now())
}

// Google Ads: uploaded monthly report files (stored base64 in the DB).
model AdReport {
  id        Int      @id @default(autoincrement())
  clientId  Int
  month     String   @default("")
  year      String   @default("")
  filename  String   @default("")
  mime      String   @default("application/pdf")
  data      String   @default("") // base64-encoded file contents
  createdAt DateTime @default(now())
}

model Contact {
  id       Int    @id @default(autoincrement())
  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  title    String @default("Contact")
  email    String @default("—")
  phone    String @default("—")
}

model Job {
  id              Int     @id @default(autoincrement())
  client          String // client name, mirrors prototype
  salesDate       String
  jobType         String
  status          String
  dev             Int     @default(0)
  host            Int     @default(0) // annual hosting
  hostingMonth    String  @default("—")
  region          String  @default("")
  thisMonth       Boolean @default(false)
  ws              String  @default("schoolwebsites")
  salesChannel    String  @default("")
  referralPartner String  @default("")
}

model Sale {
  id        Int        @id @default(autoincrement())
  name      String
  town      String     @default("")
  category  String     @default("Primary")
  region    String     @default("")
  roll      Int        @default(0)
  principal String     @default("—")
  email     String     @default("")
  stage     String     @default("New")
  ws        String     @default("schoolwebsites")
  auditUrl  String     @default("") // Caddie Optimise shareable SEO report (set via webhook)
  auditPdf  String     @default("") // report PDF url
  auditScore Int? // overall SEO score at last report
  auditAt   String     @default("") // display date of the last audit
  proposalUrl String   @default("") // Caddie Optimise client proposal PDF (set via webhook)
  proposalAt  String   @default("") // display date of the proposal
  notes     SaleNote[]
  tasks     SaleTask[]
}

model SaleNote {
  id        Int      @id @default(autoincrement())
  saleId    Int
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  text      String
  ts        String
  createdAt DateTime @default(now())
}

model SaleTask {
  id     Int     @id @default(autoincrement())
  saleId Int
  sale   Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  text   String
  due    String  @default("")
  done   Boolean @default(false)
}

model EmailTemplate {
  id      Int    @id @default(autoincrement())
  name    String
  subject String @default("")
  body    String @default("")
}

model SalesChannel {
  id    Int    @id @default(autoincrement())
  name  String @unique
  order Int    @default(0)
}

model ReferralPartner {
  id    Int    @id @default(autoincrement())
  name  String @unique
  order Int    @default(0)
}

model Target {
  key   String @id
  value Float  @default(0)
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String
  passwordHash String? // null until the user sets a password (invited users)
  role         String    @default("member") // 'super_admin' | 'admin' | 'member'
  status       String    @default("invited") // 'active' | 'invited'
  createdAt    DateTime  @default(now())
  // Set-password token (used for both invite acceptance and forgot-password)
  tokenHash    String?
  tokenExpiry  DateTime?
}

model GmailAccount {
  ws           String   @id // 'caddie' | 'schoolwebsites'
  email        String   @default("") // the connected mailbox address
  refreshToken String // AES-256-GCM encrypted, base64
  connectedAt  DateTime @default(now())
  connectedBy  String   @default("") // admin email who connected it
}

model SentEmail {
  id      Int      @id @default(autoincrement())
  kind    String // 'client' | 'sale'
  refId   Int
  subject String
  body    String
  day     String
  time    String
  sentAt  DateTime @default(now())
}
